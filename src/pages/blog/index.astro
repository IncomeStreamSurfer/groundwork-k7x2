---
import Base from '../../layouts/Base.astro';
import { getPublishedPosts } from '../../lib/supabase';
export const prerender = false;
const posts = await getPublishedPosts();
const siteUrl = Astro.site?.toString().replace(/\/$/, '') || '';
const structuredData = [
  { "@context":"https://schema.org","@type":"Blog", name:"The Groundwork Journal", url:`${siteUrl}/blog` },
  { "@context":"https://schema.org","@type":"BreadcrumbList", itemListElement:[{"@type":"ListItem",position:1,name:"Home",item:siteUrl},{"@type":"ListItem",position:2,name:"Journal",item:`${siteUrl}/blog`}]},
];
---
<Base title="The Groundwork Journal | Coffee & Brewing Guides" description="Brew guides, tasting notes, farmer stories, and the craft behind great specialty coffee. The Groundwork Journal." structuredData={structuredData}>
  <section class="max-w-4xl mx-auto px-6 pt-16 pb-12">
    <nav class="text-xs text-[#2a1810]/60 mb-4"><a href="/" class="hover:text-[#c9783d]">Home</a> / Journal</nav>
    <p class="text-xs uppercase tracking-[0.3em] text-[#c9783d] mb-3">The Groundwork Journal</p>
    <h1 class="font-display text-4xl md:text-5xl font-medium text-[#2a1810] leading-tight">Coffee Stories, Brew Guides &amp; Craft Notes</h1>
  </section>
  <section class="max-w-4xl mx-auto px-6 pb-20">
    {posts.length ? (
      <div class="space-y-10">
        {posts.map((p: any) => (
          <article class="border-b border-[#2a1810]/10 pb-10">
            <a href={`/blog/${p.slug}`} class="block group">
              <div class="text-xs uppercase tracking-[0.2em] text-[#c9783d] mb-2">{new Date(p.published_at).toLocaleDateString('en-US',{year:'numeric',month:'long',day:'numeric'})}</div>
              <h2 class="font-display text-3xl font-medium text-[#2a1810] group-hover:text-[#c9783d] transition-colors">{p.title}</h2>
              {p.excerpt && <p class="mt-3 text-[#2a1810]/70">{p.excerpt}</p>}
              <span class="mt-4 inline-block text-sm font-medium text-[#c9783d]">Read the piece →</span>
            </a>
          </article>
        ))}
      </div>
    ) : (
      <div class="rounded-2xl bg-[#e8d9c0] p-12 text-center">
        <p class="text-xs uppercase tracking-[0.3em] text-[#c9783d] mb-3">Brewing soon</p>
        <h2 class="font-display text-3xl md:text-4xl font-medium text-[#2a1810] mb-3">Fresh articles soon</h2>
        <p class="text-[#2a1810]/75 max-w-lg mx-auto">We're working on brew guides, origin stories, and tasting notes. Sign up below and you'll hear first — no spam, just coffee.</p>
        <form action="/api/subscribe" method="post" class="mt-6 flex gap-2 max-w-sm mx-auto">
          <input required type="email" name="email" placeholder="Your email" class="flex-1 bg-white border border-[#2a1810]/20 px-4 py-3 rounded text-sm focus:outline-none focus:border-[#c9783d]" />
          <button class="px-5 py-3 bg-[#2a1810] text-white text-sm font-medium rounded hover:bg-[#3d2817]">Subscribe</button>
        </form>
      </div>
    )}
  </section>
</Base>
