---
import Base from '../layouts/Base.astro';
import ProductCard from '../components/ProductCard.astro';
import { getProducts } from '../lib/supabase';
export const prerender = false;
const all = await getProducts();
const featured = all.filter(p => p.featured).slice(0, 6);
const coffees = all.filter(p => p.category === 'coffee').slice(0, 3);
const gear = all.filter(p => p.category === 'equipment').slice(0, 3);
const siteUrl = Astro.site?.toString().replace(/\/$/, '') || '';
const structuredData = [ { "@context":"https://schema.org", "@type":"ItemList", name: "Featured products at Groundwork Coffee Co.", itemListElement: featured.map((p, i) => ({ "@type":"ListItem", position: i + 1, url: `${siteUrl}/shop/${p.category === 'coffee' ? 'coffee' : p.category === 'equipment' ? 'brewing-equipment' : 'bundles'}/${p.slug}`, name: p.name })) } ];
---
<Base title="Groundwork Coffee Co. | Specialty Coffee & Brewing Tools" description="Shop premium single-origin coffees and precision brewing tools at Groundwork Coffee Co. Elevate every cup. Free shipping on orders over $50." structuredData={structuredData}>
  <section class="relative overflow-hidden">
    <div class="max-w-6xl mx-auto px-6 pt-16 pb-24 md:pt-24 md:pb-32 grid md:grid-cols-2 gap-12 items-center">
      <div>
        <p class="text-xs uppercase tracking-[0.3em] text-[#c9783d] mb-4">From bean to brew, every detail matters</p>
        <h1 class="font-display text-5xl md:text-7xl font-medium leading-[1.02] text-[#2a1810]">Specialty Coffee &amp; Brewing Tools for the Serious Cup</h1>
        <p class="mt-6 text-lg text-[#2a1810]/70 max-w-xl">Roasted fresh to order. Paired with the precision tools home baristas actually use. Groundwork Coffee Co. exists for people who refuse to settle for an ordinary morning cup.</p>
        <div class="mt-8 flex flex-wrap gap-3">
          <a href="/shop/coffee" class="px-6 py-3 bg-[#2a1810] text-white rounded-md font-medium hover:bg-[#3d2817] transition-colors">Shop coffee</a>
          <a href="/shop/brewing-equipment" class="px-6 py-3 border border-[#2a1810] text-[#2a1810] rounded-md font-medium hover:bg-[#2a1810] hover:text-white transition-colors">Shop brewing gear</a>
        </div>
        <div class="mt-10 flex flex-wrap gap-8 text-xs uppercase tracking-[0.2em] text-[#2a1810]/60"><span>★ Free US shipping $50+</span><span>★ Roasted to order</span><span>★ Specialty grade (85+)</span></div>
      </div>
      <div class="relative">
        <div class="aspect-[4/5] rounded-2xl overflow-hidden bg-[#e8d9c0]"><img src="https://images.unsplash.com/photo-1559525839-d9acfd3921cc?w=1200&q=80" alt="Freshly roasted specialty coffee beans in a hand-poured cup" class="w-full h-full object-cover" /></div>
        <div class="absolute -bottom-6 -left-6 bg-white rounded-xl shadow-xl p-5 max-w-[240px] hidden md:block"><div class="text-xs uppercase tracking-[0.2em] text-[#c9783d] mb-1">This week's flight</div><div class="font-display text-lg font-medium">Ethiopia Yirgacheffe</div><div class="text-xs text-[#2a1810]/60 mt-1">Jasmine · Bergamot · Stone fruit</div></div>
      </div>
    </div>
  </section>

  <section class="border-y border-[#2a1810]/10 bg-white"><div class="max-w-6xl mx-auto px-6 py-14 grid md:grid-cols-3 gap-10">
    <div><div class="text-3xl font-display font-medium text-[#c9783d]">01</div><h2 class="font-display text-xl font-medium mt-2">Sourced with intention</h2><p class="text-sm text-[#2a1810]/70 mt-2">Every lot scores 85+ on the SCA scale. We work directly with importers we trust and can name.</p></div>
    <div><div class="text-3xl font-display font-medium text-[#c9783d]">02</div><h2 class="font-display text-xl font-medium mt-2">Roasted to order</h2><p class="text-sm text-[#2a1810]/70 mt-2">Beans ship within 72 hours of roasting. You taste the coffee at its absolute peak, never stale.</p></div>
    <div><div class="text-3xl font-display font-medium text-[#c9783d]">03</div><h2 class="font-display text-xl font-medium mt-2">Tools that actually matter</h2><p class="text-sm text-[#2a1810]/70 mt-2">A grinder that improves every cup, a kettle that lets you control temperature, a scale that gets ratios right.</p></div>
  </div></section>

  <section class="max-w-6xl mx-auto px-6 py-20"><div class="flex items-end justify-between mb-10"><div><p class="text-xs uppercase tracking-[0.3em] text-[#c9783d] mb-2">On the roast rack</p><h2 class="font-display text-4xl font-medium text-[#2a1810]">This week's coffees</h2></div><a href="/shop/coffee" class="text-sm font-medium text-[#c9783d] underline underline-offset-4">See all coffees →</a></div><div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-8">{coffees.map(p => <ProductCard product={p} />)}</div></section>

  <section class="bg-[#2a1810] text-[#e8d9c0] py-20"><div class="max-w-4xl mx-auto px-6 text-center"><p class="text-xs uppercase tracking-[0.3em] text-[#c9783d] mb-3">The Groundwork philosophy</p><h2 class="font-display text-4xl md:text-5xl font-medium text-white leading-tight">Great coffee shouldn't be a mystery.</h2><p class="mt-5 text-[#e8d9c0]/80 text-lg max-w-2xl mx-auto">We built Groundwork because the difference between a forgettable cup and an extraordinary one isn't talent — it's the right beans, the right tools, and a few principles that make everything click. <a href="/about" class="underline underline-offset-4 text-white">Read our story →</a></p></div></section>

  <section class="max-w-6xl mx-auto px-6 py-20"><div class="flex items-end justify-between mb-10"><div><p class="text-xs uppercase tracking-[0.3em] text-[#c9783d] mb-2">Precision gear</p><h2 class="font-display text-4xl font-medium text-[#2a1810]">Home barista essentials</h2></div><a href="/shop/brewing-equipment" class="text-sm font-medium text-[#c9783d] underline underline-offset-4">See all gear →</a></div><div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-8">{gear.map(p => <ProductCard product={p} />)}</div></section>

  <section class="max-w-6xl mx-auto px-6 pb-20"><div class="grid md:grid-cols-2 rounded-2xl overflow-hidden bg-[#e8d9c0]"><div class="p-10 md:p-14"><p class="text-xs uppercase tracking-[0.3em] text-[#c9783d] mb-3">Coffee + gear bundles</p><h2 class="font-display text-4xl font-medium text-[#2a1810] leading-tight">Everything you need to brew better — together.</h2><p class="mt-4 text-[#2a1810]/70">Save 15–20% when you pair fresh-roasted coffees with matched brewing tools. Built to gift, built to upgrade your setup.</p><a href="/shop/bundles" class="inline-block mt-6 px-6 py-3 bg-[#2a1810] text-white rounded-md font-medium hover:bg-[#3d2817] transition-colors">Explore bundles</a></div><div class="h-full min-h-[300px] bg-cover bg-center" style="background-image:url('https://images.unsplash.com/photo-1494314671902-399b18174975?w=1200&q=80')" role="img" aria-label="Curated coffee and brewing gear bundle"></div></div></section>
</Base>
