---
import "../styles/global.css";
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Groundwork Coffee Co. — Building…</title>
    <meta name="description" content="Specialty coffee + precision brewing tools. Site launching soon." />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Fraunces:ital,opsz,wght@0,9..144,400;0,9..144,500;0,9..144,600;1,9..144,500&family=Inter:wght@400;500;600&display=swap" rel="stylesheet" />
  </head>
  <body class="min-h-screen flex items-center justify-center">
    <div class="text-center max-w-xl px-6">
      <div class="inline-block mb-8 relative">
        <svg viewBox="0 0 100 100" class="w-20 h-20 mx-auto" aria-hidden="true">
          <path d="M30 70 Q35 60 30 50 Q25 40 30 30" stroke="#c9783d" stroke-width="3" fill="none" class="animate-steam" />
          <path d="M50 70 Q55 60 50 50 Q45 40 50 30" stroke="#c9783d" stroke-width="3" fill="none" class="animate-steam" style="animation-delay: 0.4s" />
          <path d="M70 70 Q75 60 70 50 Q65 40 70 30" stroke="#c9783d" stroke-width="3" fill="none" class="animate-steam" style="animation-delay: 0.8s" />
          <rect x="20" y="70" width="60" height="18" rx="4" fill="#2a1810" />
          <rect x="80" y="74" width="10" height="10" rx="2" fill="#2a1810" />
        </svg>
      </div>
      <p class="text-xs uppercase tracking-[0.3em] text-[#c9783d] mb-3">Groundwork Coffee Co.</p>
      <h1 class="font-display text-5xl md:text-6xl font-medium mb-4">Brewing something special…</h1>
      <p class="text-[#3d2817]/70 text-lg">Specialty coffees, precision tools, and a home for serious home baristas. The shop opens in moments — the beans are roasting as we speak.</p>
      <div class="mt-10 flex justify-center gap-2">
        <span class="w-2 h-2 bg-[#c9783d] rounded-full animate-pulse"></span>
        <span class="w-2 h-2 bg-[#c9783d] rounded-full animate-pulse" style="animation-delay: 0.2s"></span>
        <span class="w-2 h-2 bg-[#c9783d] rounded-full animate-pulse" style="animation-delay: 0.4s"></span>
      </div>
    </div>
  </body>
</html>
