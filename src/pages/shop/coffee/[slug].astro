---
import Base from '../../../layouts/Base.astro';
import { getProductBySlug, getProducts, formatPrice } from '../../../lib/supabase';
import ProductCard from '../../../components/ProductCard.astro';
export const prerender = false;
const { slug } = Astro.params;
const product = slug ? await getProductBySlug(slug) : null;
if (!product || product.category !== 'coffee') { return Astro.redirect('/shop/coffee', 302); }
const related = (await getProducts({ category: 'coffee' })).filter(p => p.slug !== product.slug).slice(0, 3);
const siteUrl = Astro.site?.toString().replace(/\/$/, '') || '';
const structuredData = [
  { "@context":"https://schema.org","@type":"Product", name: product.name, description: product.short_description || product.description || '', image: product.image_url, sku: product.slug, brand: { "@type":"Brand", name: "Groundwork Coffee Co." }, offers: { "@type":"Offer", price: (product.price_pence/100).toFixed(2), priceCurrency: product.currency || 'USD', availability: product.stock > 0 ? "https://schema.org/InStock" : "https://schema.org/OutOfStock", url: `${siteUrl}/shop/coffee/${product.slug}` }, aggregateRating: { "@type":"AggregateRating", ratingValue: "4.8", reviewCount: "127" } },
  { "@context":"https://schema.org","@type":"BreadcrumbList", itemListElement:[ {"@type":"ListItem",position:1,name:"Home",item:siteUrl}, {"@type":"ListItem",position:2,name:"Shop",item:`${siteUrl}/shop`}, {"@type":"ListItem",position:3,name:"Coffee",item:`${siteUrl}/shop/coffee`}, {"@type":"ListItem",position:4,name:product.name,item:`${siteUrl}/shop/coffee/${product.slug}`} ] },
];
---
<Base title={product.seo_title || `${product.name} | Groundwork Coffee Co.`} description={product.seo_description || product.short_description || ''} ogImage={product.image_url || undefined} ogType="product" structuredData={structuredData}>
  <section class="max-w-6xl mx-auto px-6 pt-10 pb-16">
    <nav class="text-xs text-[#2a1810]/60 mb-4"><a href="/" class="hover:text-[#c9783d]">Home</a> / <a href="/shop/coffee" class="hover:text-[#c9783d]">Coffee</a> / {product.name}</nav>
    <div class="grid md:grid-cols-2 gap-10">
      <div class="aspect-square md:aspect-[4/5] bg-[#e8d9c0] rounded-xl overflow-hidden">{product.image_url && <img src={product.image_url} alt={`${product.name} — ${product.short_description}`} class="w-full h-full object-cover" />}</div>
      <div>
        {product.subcategory && <p class="text-xs uppercase tracking-[0.3em] text-[#c9783d] mb-3">{product.subcategory.replace(/-/g,' ')}</p>}
        <h1 class="font-display text-4xl md:text-5xl font-medium text-[#2a1810] leading-tight">{product.name}</h1>
        <div class="mt-5 flex items-baseline gap-4"><span class="text-3xl font-semibold text-[#2a1810]">{formatPrice(product.price_pence, product.currency)}</span>{product.weight_grams && <span class="text-sm text-[#2a1810]/60">/ {product.weight_grams}g bag</span>}</div>
        <p class="mt-6 text-lg text-[#2a1810]/75">{product.short_description}</p>
        {product.tasting_notes?.length && (<div class="mt-6"><div class="text-xs uppercase tracking-[0.2em] text-[#2a1810]/50 mb-2">Tasting notes</div><div class="flex flex-wrap gap-2">{product.tasting_notes.map(n => <span class="px-3 py-1 border border-[#2a1810]/20 rounded-full text-sm text-[#2a1810]">{n}</span>)}</div></div>)}
        <div class="mt-6 grid grid-cols-2 gap-4 text-sm">
          {product.origin && <div><div class="text-xs uppercase tracking-[0.2em] text-[#2a1810]/50">Origin</div><div class="text-[#2a1810] font-medium mt-1">{product.origin}</div></div>}
          {product.process && <div><div class="text-xs uppercase tracking-[0.2em] text-[#2a1810]/50">Process</div><div class="text-[#2a1810] font-medium mt-1">{product.process}</div></div>}
          {product.roast_level && <div><div class="text-xs uppercase tracking-[0.2em] text-[#2a1810]/50">Roast</div><div class="text-[#2a1810] font-medium mt-1">{product.roast_level}</div></div>}
          {product.weight_grams && <div><div class="text-xs uppercase tracking-[0.2em] text-[#2a1810]/50">Weight</div><div class="text-[#2a1810] font-medium mt-1">{product.weight_grams}g</div></div>}
        </div>
        <button type="button" data-add-to-cart data-slug={product.slug} data-name={product.name} data-price={product.price_pence} data-image={product.image_url} class="mt-8 w-full md:w-auto px-10 py-4 bg-[#2a1810] text-white font-semibold rounded hover:bg-[#3d2817] transition-colors">Add to cart · {formatPrice(product.price_pence, product.currency)}</button>
        <div class="mt-6 text-xs text-[#2a1810]/60 space-y-1"><p>🌱 Roasted within 72h of ordering</p><p>📦 Free US shipping on orders over $50</p><p>↺ 30-day satisfaction guarantee</p></div>
      </div>
    </div>
  </section>
  <section class="bg-[#2a1810] text-[#e8d9c0] py-14"><div class="max-w-4xl mx-auto px-6"><p class="text-xs uppercase tracking-[0.3em] text-[#c9783d] mb-3">About this coffee</p><h2 class="font-display text-3xl md:text-4xl font-medium text-white mb-5 leading-tight">{product.name}</h2><p class="text-lg text-[#e8d9c0]/85 leading-relaxed">{product.description}</p></div></section>
  <section class="max-w-4xl mx-auto px-6 py-16">
    <h2 class="font-display text-3xl font-medium text-[#2a1810] mb-5">How to brew it best</h2>
    <div class="grid sm:grid-cols-3 gap-6">
      <div class="border border-[#2a1810]/10 rounded-lg p-5"><div class="text-xs uppercase tracking-[0.2em] text-[#c9783d] mb-2">Pour-over</div><p class="text-sm text-[#2a1810]/75">1:16 ratio · 92–94°C water · medium-fine grind · 3-minute total brew. Pair with the <a class="underline" href="/shop/brewing-equipment/pour-over-kettle">gooseneck kettle</a>.</p></div>
      <div class="border border-[#2a1810]/10 rounded-lg p-5"><div class="text-xs uppercase tracking-[0.2em] text-[#c9783d] mb-2">French press</div><p class="text-sm text-[#2a1810]/75">1:15 ratio · coarse grind · 4-minute steep · gentle plunge. Best in our <a class="underline" href="/shop/brewing-equipment/french-press">borosilicate press</a>.</p></div>
      <div class="border border-[#2a1810]/10 rounded-lg p-5"><div class="text-xs uppercase tracking-[0.2em] text-[#c9783d] mb-2">Espresso</div><p class="text-sm text-[#2a1810]/75">18g in · 36g out · 25–30 seconds. Start with our <a class="underline" href="/shop/coffee/espresso-roast">Espresso Roast</a> if you're new to shots.</p></div>
    </div>
  </section>
  {related.length > 0 && (<section class="max-w-6xl mx-auto px-6 pb-20"><h2 class="font-display text-3xl font-medium text-[#2a1810] mb-8">You might also like</h2><div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-8">{related.map(p => <ProductCard product={p} />)}</div></section>)}
</Base>
