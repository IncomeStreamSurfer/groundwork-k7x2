---
import Base from '../../../layouts/Base.astro';
import ProductCard from '../../../components/ProductCard.astro';
import { getProducts } from '../../../lib/supabase';
export const prerender = false;
const products = await getProducts({ category: 'equipment' });
const siteUrl = Astro.site?.toString().replace(/\/$/, '') || '';
const structuredData = [
  { "@context":"https://schema.org", "@type":"CollectionPage", name:"Coffee Brewing Equipment", url: `${siteUrl}/shop/brewing-equipment` },
  { "@context":"https://schema.org","@type":"ItemList", itemListElement: products.map((p,i)=>({"@type":"ListItem",position:i+1,url:`${siteUrl}/shop/brewing-equipment/${p.slug}`,name:p.name})) },
  { "@context":"https://schema.org","@type":"BreadcrumbList", itemListElement:[ {"@type":"ListItem",position:1,name:"Home",item:siteUrl}, {"@type":"ListItem",position:2,name:"Shop",item:`${siteUrl}/shop`}, {"@type":"ListItem",position:3,name:"Brewing Equipment",item:`${siteUrl}/shop/brewing-equipment`} ] },
];
---
<Base title="Coffee Brewing Equipment & Tools | Groundwork Coffee Co." description="From pour-over kettles to burr grinders and espresso tampers — shop precision brewing tools built for the home barista." structuredData={structuredData}>
  <section class="max-w-6xl mx-auto px-6 pt-16 pb-10">
    <nav class="text-xs text-[#2a1810]/60 mb-4"><a href="/" class="hover:text-[#c9783d]">Home</a> / <a href="/shop" class="hover:text-[#c9783d]">Shop</a> / Brewing Equipment</nav>
    <p class="text-xs uppercase tracking-[0.3em] text-[#c9783d] mb-3">Built for home baristas</p>
    <h1 class="font-display text-5xl md:text-6xl font-medium text-[#2a1810] leading-tight">Coffee Brewing Equipment for Every Method</h1>
    <p class="mt-5 max-w-2xl text-lg text-[#2a1810]/70">Upgrade the brew without upgrading the café budget. Groundwork's <strong>coffee brewing equipment</strong> covers every method — from the <a class="underline" href="/shop/brewing-equipment/pour-over-kettle">gooseneck pour-over kettle</a> and <a class="underline" href="/shop/brewing-equipment/burr-grinder">conical burr grinder</a> to the <a class="underline" href="/shop/brewing-equipment/french-press">classic French press</a> and <a class="underline" href="/shop/brewing-equipment/espresso-tamper">calibrated espresso tamper</a>.</p>
    <p class="mt-3 max-w-2xl text-[#2a1810]/70">Pair any of our tools with a bag of <a class="underline" href="/shop/coffee">fresh-roasted specialty coffee</a> or grab a full kit in our <a class="underline" href="/shop/bundles">bundles</a>.</p>
  </section>
  <section class="max-w-6xl mx-auto px-6 py-10">
    <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-8">{products.map(p => <ProductCard product={p} />)}</div>
  </section>
  <section class="max-w-4xl mx-auto px-6 py-16">
    <h2 class="font-display text-3xl font-medium text-[#2a1810] mb-5">Which tool first?</h2>
    <div class="space-y-5 text-[#2a1810]/75">
      <p><strong class="text-[#2a1810]">Start with the grinder.</strong> A good <a class="underline" href="/shop/brewing-equipment/burr-grinder">conical burr grinder</a> unlocks flavor in every bean. It's the single highest-impact upgrade for home brewing.</p>
      <p><strong class="text-[#2a1810]">Next, a scale.</strong> Ratios matter. Our <a class="underline" href="/shop/brewing-equipment/coffee-scale">digital coffee scale</a> gets you within 0.1g and times your brew at the same time.</p>
      <p><strong class="text-[#2a1810]">Then the brewer.</strong> Pour-over? Grab the <a class="underline" href="/shop/brewing-equipment/pour-over-kettle">gooseneck kettle</a>. Full-bodied? Go with the <a class="underline" href="/shop/brewing-equipment/french-press">French press</a>. Espresso? Our <a class="underline" href="/shop/brewing-equipment/espresso-tamper">calibrated 58mm tamper</a> is the barista upgrade that separates good shots from great ones.</p>
    </div>
    <p class="mt-8 text-[#2a1810]/60 text-sm">Still unsure? <a class="underline" href="/faq">Check the FAQ</a> or <a class="underline" href="/contact">drop us a line</a>.</p>
  </section>
</Base>
